# ════════════════════════════════════════════════════════════
# The Alpine Homestay Jakhol — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ════════════════════════════════════════════════════════════

# ── Site URL (no trailing slash) ──────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.thealpinehomestay.in

# ── Google Analytics 4 Measurement ID ─────────────────────
# Get from: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Formspree Form ID ──────────────────────────────────────
# Get from: https://formspree.io → My Forms → Copy form ID
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id

# ── NODE_ENV (set automatically by Next.js / Vercel) ───────
# NODE_ENV=production
